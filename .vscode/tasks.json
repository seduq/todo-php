{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CakePHP: Clear Cache",
      "type": "shell",
      "command": "bin/cake cache clear_all",
      "problemMatcher": [],
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "CakePHP: Run Migrations",
      "type": "shell",
      "command": "bin/cake migrations migrate",
      "problemMatcher": [],
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Composer: Install",
      "type": "shell",
      "command": "composer install",
      "problemMatcher": [],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Composer: Update",
      "type": "shell",
      "command": "composer update",
      "problemMatcher": [],
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
